<!doctype html>
<html lang="{{ language | escape }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{% if subject != blank %}{{ subject | escape }}{% else %}RSVP — {{ eventName | escape }}{% endif %}</title>
<style>
body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;font-size:16px;color:#111827;line-height:1.5}
.card{max-width:40rem;margin:3rem auto;background:#fff;padding:2rem;border-radius:1rem;box-shadow:0 1px 3px #0002}
h1{margin-top:0;font-size:1.75rem}
.muted{color:#6b7280;margin-top:0}
.langs{font-size:.85rem;margin-bottom:1rem}
.langs a{color:#6b7280;text-decoration:none;margin-right:.75rem}
.langs a.active{color:#111827;font-weight:700;text-decoration:underline}
.preview{position:sticky;top:0;background:#fdba74;color:#9a3412;text-align:center;font-size:.875rem;padding:.35rem .75rem;z-index:1}
.block{margin:2rem 0}
.block-title{font-size:1.4rem;font-weight:700;margin:0 0 .5rem}
.block-sub{font-size:1.05rem;font-weight:600;margin:1rem 0 .5rem}
.body{margin-bottom:1rem}
.body p{margin:0 0 1rem}
label{display:block;margin:.75rem 0 .3rem;font-weight:600}
input[type=text],input[type=email],input[type=tel],input[type=number],input[type=date],input[type=time],input[type=url],select,textarea{box-sizing:border-box;width:100%;padding:.6rem;border:1px solid #d1d5db;border-radius:.5rem;font:inherit;font-size:16px}
.choice{display:flex;align-items:baseline;gap:.5rem;margin:.35rem 0}
.choice label{display:inline;margin:0;font-weight:400}
.choice-note{color:#6b7280;font-size:.85rem;margin-left:1.4rem}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
@media (max-width:480px){.grid-2{grid-template-columns:1fr}}
.plus-guest{display:flex;gap:.5rem;align-items:center;margin-bottom:.6rem}
.plus-guest .idx{color:#6b7280;min-width:1.2rem}
.plus-guest input{flex:1}
.nested{margin-left:1.5rem;padding-left:1rem;border-left:2px solid #e5e7eb}
table.info{border-collapse:collapse;margin-bottom:1rem}
table.info td{padding:.15rem .75rem .15rem 0;vertical-align:top}
.qr{text-align:center;margin:1.5rem 0}
.qr svg{border:1px solid #e5e7eb;border-radius:.5rem}
.required-note{color:#6b7280;font-size:.85rem;margin-top:1rem}
.actions{display:flex;gap:.75rem;margin-top:1.5rem}
button{border:0;border-radius:.5rem;padding:.7rem 1.2rem;font:inherit;font-weight:700;cursor:pointer}
.yes{background:#4f46e5;color:#fff}
.no{background:none;color:#6b7280;text-decoration:underline}
</style>
</head>
<body>
{% if preview %}<div class="preview">Preview of RSVP form: {{ previewName | escape }}</div>{% endif %}
<main class="card">
  {% if showEventLabel %}
  <p class="muted">{{ eventName | escape }}{% if listName != blank %} · {{ listName | escape }}{% endif %}</p>
  {% endif %}
  {% if hasEdm and showLanguageSelector %}
  <nav class="langs">
    {% for lang in languages %}<a href="{{ lang.href | escape }}"{% if lang.active %} class="active"{% endif %}>{{ lang.label }}</a>{% endfor %}
  </nav>
  {% endif %}

  {% if hasEdm %}
    {% if heading != blank %}<h1>{{ heading | escape }}</h1>{% endif %}
    {% if bodyHtml != blank %}<div class="body">{{ bodyHtml }}</div>{% endif %}
  {% else %}
    <h1>RSVP</h1>
    <p>Hello {{ guestName | escape }}, please let us know whether you can attend.</p>
  {% endif %}

  <form method="post" action="{{ action | escape }}">
    {% if hasEdm %}
      {% for block in blocks %}
        {% case block.type %}
          {% when 'picture' %}{% render 'public/picture', block: block %}
          {% when 'paragraph' %}{% render 'public/paragraph', block: block %}
          {% when 'table' %}{% render 'public/table', block: block %}
          {% when 'button' %}{% render 'public/button', block: block %}
          {% when 'spacer' %}{% render 'public/spacer', block: block %}
          {% when 'rsvp-location' %}{% render 'public/rsvp-location', block: block %}
          {% when 'rsvp-date-time' %}{% render 'public/rsvp-date-time', block: block %}
          {% when 'rsvp-meal-preferences' %}{% render 'public/rsvp-meal-preferences', block: block, prefix: '', showTitle: true %}
          {% when 'rsvp-plus-one' %}{% render 'public/rsvp-plus-one', block: block, meals: meals %}
          {% when 'rsvp-custom' %}{% render 'public/rsvp-custom', block: block %}
          {% when 'rsvp-travel-hotel' %}{% render 'public/rsvp-travel-hotel', block: block %}
          {% when 'rsvp-pickup' %}{% render 'public/rsvp-pickup', block: block %}
          {% when 'rsvp-sessions' %}{% render 'public/rsvp-sessions', block: block %}
          {% when 'rsvp-qrcode' %}{% render 'public/rsvp-qrcode', block: block %}
          {% when 'rsvp-public-form' %}{% render 'public/rsvp-public-form', block: block %}
        {% endcase %}
      {% endfor %}
      <div class="required-note">* required</div>
    {% else %}
      <label>Additional guests</label>
      <input type="number" min="0" name="plus_guests" value="{{ plusGuests | escape }}">
      <label>Message (optional)</label>
      <textarea name="message" rows="4" placeholder="Anything the event team should know?"></textarea>
    {% endif %}

    <div class="actions">
      <button class="yes" name="status" value="confirmed" type="submit">{{ acceptLabel | default: 'Accept' | escape }}</button>
      {% unless hideDecline %}
      <button class="no" name="status" value="declined" type="submit">Decline</button>
      {% endunless %}
    </div>
  </form>
</main>
</body>
</html>
