<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Order {{ code | escape }}</title>
{% if refreshing %}<meta http-equiv="refresh" content="5">{% endif %}
<style>
body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;color:#111827}
.card{max-width:34rem;margin:3rem auto;background:#fff;padding:2rem;border-radius:1rem;box-shadow:0 1px 3px #0002;text-align:center}
h1{margin:0 0 .25rem;font-size:1.4rem}
.muted{color:#6b7280;font-size:.9rem}
.badge{display:inline-block;padding:.25rem .75rem;border-radius:999px;font-size:.85rem;font-weight:600;margin:.5rem 0}
.paid{background:#dcfce7;color:#166534}
.waiting{background:#fef9c3;color:#854d0e}
.failed{background:#fee2e2;color:#991b1b}
.code{font-family:ui-monospace,monospace;font-size:1.15rem;letter-spacing:.08em;background:#f3f4f6;border-radius:.5rem;padding:.4rem .8rem;display:inline-block;margin:.5rem 0}
.qr{margin:1.25rem auto .5rem;max-width:220px}
.instructions{text-align:left;background:#f9fafb;border:1px solid #e5e7eb;border-radius:.6rem;padding:1rem;margin-top:1rem;white-space:pre-wrap;font-size:.95rem}
.notice{background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:.75rem 1rem;border-radius:.5rem;margin:1rem 0;font-size:.9rem;text-align:left}
</style></head>
<body><main class="card">
  <h1>{{ eventName | escape }}</h1>
  <p class="muted">{{ quantity }} ticket(s) · {{ totalLabel | escape }}</p>
  <div class="code">{{ code | escape }}</div>

  {% if cancelled and paid == false %}
  <div class="notice">Payment was not completed. You can reopen your invitation link to try again.</div>
  {% endif %}

  {% if paid %}
  <div><span class="badge paid">Confirmed</span></div>
  <div class="qr">{{ qrSvg }}</div>
  <p class="muted">Show this QR code at the door. A confirmation has been sent to {{ email | escape }}.</p>
  {% elsif pendingOffline %}
  <div><span class="badge waiting">Awaiting payment</span></div>
  <p class="muted">Complete the payment below and quote your order code — your tickets are confirmed once we receive it.</p>
  {% if offlineInstructions != blank %}<div class="instructions">{{ offlineInstructions | escape }}</div>{% endif %}
  {% elsif refreshing %}
  <div><span class="badge waiting">Processing payment…</span></div>
  <p class="muted">This page refreshes automatically once your payment is confirmed.</p>
  {% elsif failed %}
  <div><span class="badge failed">{{ statusLabel | escape }}</span></div>
  <p class="muted">This order is no longer active.</p>
  {% else %}
  <div><span class="badge waiting">{{ statusLabel | escape }}</span></div>
  {% endif %}
</main></body></html>
