<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>RSVP received</title><style>body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;color:#111827;line-height:1.5}.card{max-width:34rem;margin:4rem auto;background:#fff;padding:2rem;border-radius:1rem;box-shadow:0 1px 3px #0002}.picture{display:block;max-width:100%;height:auto;border-radius:.5rem;margin:0 0 1.5rem}body.edm{background:#fff;font-family:var(--edm-font-family);font-size:var(--edm-font-size);color:var(--edm-text-color);line-height:var(--edm-line-height)}body.edm .card{max-width:40rem;margin:3rem auto;border-radius:0;box-shadow:none}body.edm h1{margin-top:0;font-size:var(--edm-headline-font-size);font-weight:400}body.edm .picture{border-radius:0}</style></head>
<body{% if hasEdm %} class="edm" style="--edm-font-family:{{ edmFontFamily | escape }};--edm-font-size:{{ edmFontSize | escape }};--edm-text-color:{{ edmTextColor | escape }};--edm-line-height:{{ edmLineHeight | escape }};--edm-headline-font-size:{{ edmHeadlineFontSize | escape }}"{% endif %}><main class="card"><h1>{{ title | default: 'Thank you' | escape }}</h1>{% if picture != blank %}<img class="picture" src="{{ picture | escape }}" alt="">{% endif %}{% if bodyHtml != blank %}<div>{{ bodyHtml }}</div>{% elsif declined %}<p>We have recorded that you cannot attend.</p>{% else %}<p>Your RSVP has been recorded. We look forward to seeing you.</p>{% endif %}</main></body></html>
