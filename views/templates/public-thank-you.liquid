<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>RSVP received</title><style>body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;color:#111827;line-height:1.5}.card{max-width:34rem;margin:4rem auto;background:#fff;padding:2rem;border-radius:1rem;box-shadow:0 1px 3px #0002}.picture{display:block;max-width:100%;height:auto;border-radius:.5rem;margin:0 0 1.5rem}.qr{text-align:center;margin:1.5rem 0}.qr svg{border:1px solid #e5e7eb;border-radius:.5rem}.code{overflow-wrap:anywhere;color:#4b5563;font:12px ui-monospace,SFMono-Regular,Menlo,monospace}.qr a{color:#4338ca}</style></head>
<body><main class="card"><h1>{{ title | default: 'Thank you' | escape }}</h1>{% if picture != blank %}<img class="picture" src="{{ picture | escape }}" alt="">{% endif %}{% if bodyHtml != blank %}<div>{{ bodyHtml }}</div>{% elsif declined %}<p>We have recorded that you cannot attend.</p>{% else %}<p>Your RSVP has been recorded. We look forward to seeing you.</p>{% endif %}{% if showQr %}<section class="qr"><h2>Your check-in pass</h2>{{ qrSvg }}{% if checkinUrl != blank %}<p><a href="{{ checkinUrl | escape }}">Open your check-in pass</a></p>{% endif %}{% if code != blank %}<p class="code">{{ code | escape }}</p>{% endif %}</section>{% endif %}</main></body></html>
