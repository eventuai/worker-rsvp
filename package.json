{
  "name": "worker-rsvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Public RSVP website backed by 0xCMS — renders EDM-driven RSVP forms from the published database.",
  "scripts": {
    "dev": "wrangler dev --local --persist-to ../cms/.wrangler/state --port 8080",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "liquidjs": "^10.27.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
